# ──────────────────────────────────────────────────────────────────────────────
# Iceberg Multi-Cloud Pipeline – Environment Variables
# Copy to .env and fill in values. NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# RUNTIME: aws_glue | fabric | local
RUNTIME=local

# Iceberg Hadoop catalog warehouse root (trailing slash recommended)
#   AWS:    s3://my-iceberg-warehouse/iceberg/
#   Fabric: abfss://container@storageaccount.dfs.core.windows.net/iceberg/
#   Local:  s3a://iceberg-warehouse/iceberg/   (MinIO)
ICEBERG_WAREHOUSE=s3a://iceberg-warehouse/iceberg/

# Catalog name used in Spark SQL (e.g. SELECT * FROM <catalog>.db.table)
ICEBERG_CATALOG=iceberg

# Path to raw source CSV/Parquet files
#   AWS:    s3://my-raw-bucket/tpch/
#   Fabric: abfss://container@storageaccount.dfs.core.windows.net/raw/tpch/
#   Local:  s3a://raw-data/tpch/
RAW_SOURCE_PATH=s3a://raw-data/tpch/

# S3-compatible endpoint (MinIO only; leave blank for AWS/Azure)
S3_ENDPOINT=http://localhost:9000

# AWS-specific
AWS_REGION=eu-west-2
KMS_KEY_ARN=

# Azure / Fabric-specific
AZURE_STORAGE_ACCOUNT=
AZURE_CONTAINER=
KEY_VAULT_URI=
FABRIC_WORKSPACE_ID=

# Persona for access-control demos: data_engineer | data_analyst | platform_admin
PERSONA=data_engineer

# MinIO credentials (local only – never use in cloud)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
